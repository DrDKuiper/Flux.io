# .env.example — copy to .env and fill in your values.
# Generated automatically by ./install.sh (recommended) or edit manually.

# ── Wazuh forwarding ─────────────────────────────────────────────────────────
# Leave WAZUH_MANAGER_IP blank to disable Suricata→Wazuh syslog forwarding.
WAZUH_MANAGER_IP=
WAZUH_MANAGER_PORT=1514

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=fluxio_password
# Host port that Postgres binds on. Change if 5432 is already taken.
POSTGRES_PORT=5432
# Full DSN used by the backend — update the password here if you changed it above.
POSTGRES_DSN=postgres://fluxio:fluxio_password@postgres:5432/fluxioclient?sslmode=disable

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_DSN=clickhouse://default:@clickhouse:9000/fluxio

# ── Network listeners ─────────────────────────────────────────────────────────
# UDP port for NetFlow v9 / IPFIX packets from routers/switches.
NETFLOW_PORT=2055
# UDP port for TZSP-encapsulated mirror traffic.
TZSP_PORT=37008
# Host port for the backend HTTP server (dashboard + API).
PORT=80

# ── Suricata ──────────────────────────────────────────────────────────────────
SURICATA_EVE_LOG_PATH=/var/log/suricata/eve.json

# ── GeoIP (MaxMind GeoLite2) ──────────────────────────────────────────────────
# Paths inside the container — mount backend/geoip/ with the .mmdb files.
# Download with: ./install.sh (prod mode) or manually from maxmind.com.
GEOIP_CITY_DB=/root/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB=/root/geoip/GeoLite2-ASN.mmdb
