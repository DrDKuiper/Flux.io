# .env.example — copy to .env and fill in your values.
# Generated automatically by ./install.sh (recommended) or edit manually.

# ── Auth ──────────────────────────────────────────────────────────────────────
# HS256 signing secret for JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=
# Initial admin (created only on first boot when the users table is empty).
ADMIN_USERNAME=admin
# Leave blank to auto-generate a password (printed once in the backend logs).
ADMIN_PASSWORD=

# ── Wazuh forwarding ─────────────────────────────────────────────────────────
# Leave WAZUH_MANAGER_IP blank to disable Suricata→Wazuh syslog forwarding.
WAZUH_MANAGER_IP=
WAZUH_MANAGER_PORT=1514

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=fluxio_password
# Host port that Postgres binds on. Change if 5432 is already taken.
POSTGRES_PORT=5432
# Full DSN for the backend. When running via Docker Compose, compose rebuilds
# this from POSTGRES_PASSWORD automatically — set it here only when running
# the backend binary directly on the host (dev mode outside of Docker).
POSTGRES_DSN=postgres://fluxio:fluxio_password@postgres:5432/fluxioclient?sslmode=disable

# ── ClickHouse ────────────────────────────────────────────────────────────────
# Override the DSN here for non-standard ClickHouse deployments (e.g. remote).
# When using Docker Compose with defaults, this variable is not required.
CLICKHOUSE_DSN=clickhouse://default:@clickhouse:9000/fluxio

# ── Network listeners ─────────────────────────────────────────────────────────
# UDP port for NetFlow v9 / IPFIX packets from routers/switches.
NETFLOW_PORT=2055
# UDP port for TZSP-encapsulated mirror traffic.
TZSP_PORT=37008
# Host port for the backend HTTP server (dashboard + API).
PORT=80

# ── Suricata ──────────────────────────────────────────────────────────────────
SURICATA_EVE_LOG_PATH=/var/log/suricata/eve.json

# ── GeoIP (MaxMind GeoLite2) ──────────────────────────────────────────────────
# These paths are fixed inside the Docker container (/root/geoip is the mount
# point of ./backend/geoip/ on the host). Override only when running the
# backend binary directly outside of Docker.
# To populate the .mmdb files: run ./install.sh (prod mode) or download from
# https://www.maxmind.com/en/geolite2/signup
GEOIP_CITY_DB=/root/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB=/root/geoip/GeoLite2-ASN.mmdb
